# Authentication credentials (copy to .env.local and fill in real values)
AUTH_EMAIL=your@email.com
AUTH_PASSWORD=yourpassword

# JWT signing secret — minimum 32 characters
AUTH_SECRET=minimum-32-character-secret-key-here-replace-me

# Base URL of the JSON Server mock API, as reachable from the browser (must be NEXT_PUBLIC_ —
# read from client components)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Optional: base URL of the mock API as reachable from the Next.js server process, if different
# from NEXT_PUBLIC_API_BASE_URL. Only needed under Docker Compose, where the server process
# must reach the mock-api container via its internal Docker network hostname. Falls back to
# NEXT_PUBLIC_API_BASE_URL if unset.
# API_BASE_URL=http://mock-api:3001
